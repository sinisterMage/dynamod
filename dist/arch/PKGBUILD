# Maintainer: Ofek Bickel
# Local PKGBUILD for dynamod — not published to AUR yet.
# Build with: makepkg -si

pkgname=dynamod
pkgver=0.1.0
pkgrel=1
pkgdesc="A Zig+Rust PID 1 init system with OTP supervisor trees and systemd compatibility"
arch=('x86_64')
url="https://github.com/sinisterMage/dynamod"
license=('MIT')
depends=('dbus')
makedepends=('zig' 'rust' 'musl')
optdepends=(
    'seatd: Wayland compositor device access'
    'eudev: device node management'
)
backup=(
    'etc/dynamod/supervisors/root.toml'
    'etc/dynamod/logind.conf'
)

# For local builds, point this to the repo root
# or use: makepkg -si -d /path/to/dynamod
_srcdir="${startdir}/../.."

build() {
    cd "$_srcdir"
    cd zig && zig build
    cd ../rust && cargo build --release
    # PAM module: glibc target, not musl (cdylib doesn't link statically).
    cargo build --release \
        -p pam_dynamod_logind \
        --manifest-path pam_dynamod_logind/Cargo.toml \
        --target x86_64-unknown-linux-gnu
}

check() {
    cd "$_srcdir"
    cd zig && zig build test
    cd ../rust && cargo test --workspace
}

package() {
    cd "$_srcdir"

    local _zigout="zig/zig-out/bin"
    local _rustout="rust/target/x86_64-unknown-linux-musl/release"

    # Core binaries
    install -Dm755 "$_zigout/dynamod-init"        "$pkgdir/usr/sbin/dynamod-init"
    install -Dm755 "$_rustout/dynamod-svmgr"      "$pkgdir/usr/lib/dynamod/dynamod-svmgr"
    install -Dm755 "$_rustout/dynamodctl"          "$pkgdir/usr/bin/dynamodctl"
    install -Dm755 "$_rustout/dynamod-logd"        "$pkgdir/usr/lib/dynamod/dynamod-logd"

    # systemd-mimic binaries
    for bin in dynamod-logind dynamod-sd1bridge dynamod-hostnamed; do
        if [ -f "$_rustout/$bin" ]; then
            install -Dm755 "$_rustout/$bin" "$pkgdir/usr/lib/dynamod/$bin"
        fi
    done

    # Supervisor configs
    install -Dm644 config/supervisors/root.toml       "$pkgdir/etc/dynamod/supervisors/root.toml"
    install -Dm644 config/supervisors/early-boot.toml "$pkgdir/etc/dynamod/supervisors/early-boot.toml"
    install -Dm644 config/supervisors/desktop.toml    "$pkgdir/etc/dynamod/supervisors/desktop.toml"

    # Service configs
    install -dm755 "$pkgdir/etc/dynamod/services"
    for f in config/services/*.toml; do
        install -Dm644 "$f" "$pkgdir/etc/dynamod/services/$(basename "$f")"
    done

    # D-Bus policy files
    install -dm755 "$pkgdir/usr/share/dbus-1/system.d"
    for f in config/dbus-1/*.conf; do
        install -Dm644 "$f" "$pkgdir/usr/share/dbus-1/system.d/$(basename "$f")"
    done

    # logind.conf — default ships with everything commented out (= defaults)
    install -Dm644 config/logind.conf "$pkgdir/etc/dynamod/logind.conf"

    # PAM module (.so) and the documented snippet.
    local _pam_so="rust/pam_dynamod_logind/target/x86_64-unknown-linux-gnu/release/libpam_dynamod_logind.so"
    if [ -f "$_pam_so" ]; then
        install -Dm755 "$_pam_so" "$pkgdir/usr/lib/security/pam_dynamod_logind.so"
    fi
    install -Dm644 config/pam.d/dynamod-logind-snippet \
        "$pkgdir/usr/share/dynamod/pam.d/dynamod-logind-snippet"

    # Documentation
    install -Dm644 README.md      "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 docs/architecture.md   "$pkgdir/usr/share/doc/$pkgname/architecture.md"
    install -Dm644 docs/configuration.md  "$pkgdir/usr/share/doc/$pkgname/configuration.md"
    install -Dm644 LICENSE        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
